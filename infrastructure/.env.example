# Source Control Configuration
# Choose 'github' or 'codecommit'
SOURCE_PROVIDER=codecommit

# Repository Configuration
REPOSITORY_NAME=complianceshield-ai

# GitHub Configuration (required if SOURCE_PROVIDER=github)
REPOSITORY_OWNER=your-github-org
GITHUB_TOKEN_SECRET_NAME=github-oauth-token

# AWS Configuration
CDK_DEFAULT_ACCOUNT=your-aws-account-id
CDK_DEFAULT_REGION=ap-south-1
