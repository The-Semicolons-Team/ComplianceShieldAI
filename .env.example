# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id

# Environment
ENVIRONMENT=dev

# DynamoDB Tables
COMPLIANCE_METADATA_TABLE=compliance-shield-dev-compliance-metadata
USER_INTEGRATIONS_TABLE=compliance-shield-dev-user-integrations
PROCESSED_EMAILS_TABLE=compliance-shield-dev-processed-emails
NOTIFICATION_PREFERENCES_TABLE=compliance-shield-dev-notification-preferences

# SQS Queues
EMAIL_PROCESSING_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your-account-id/compliance-shield-dev-email-processing
NOTIFICATION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your-account-id/compliance-shield-dev-notification

# AWS Bedrock
BEDROCK_MODEL_ID=apac.amazon.nova-pro-v1:0
BEDROCK_REGION=ap-south-1

# Email Provider OAuth
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OAUTH_REDIRECT_URI=https://your-api-gateway-url/oauth/callback

# WhatsApp Business API
WHATSAPP_API_PROVIDER=twilio
WHATSAPP_API_KEY_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:account-id:secret:whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# API Gateway
API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# Cognito
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=your-cognito-client-id

# S3 Buckets
TEMP_ATTACHMENT_BUCKET=compliance-shield-dev-temp-attachments

# CloudWatch
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90

# Rate Limiting
API_RATE_LIMIT_PER_HOUR=1000

# Notification Settings
EMAIL_FROM_ADDRESS=noreply@complianceshield.example.com
SMS_SENDER_ID=COMPLNCE

# Testing
TEST_USER_ID=test-user-123
TEST_EMAIL_PROVIDER=gmail
