{
  "name": "ai-compliance-monitoring-msme",
  "version": "1.0.0",
  "description": "AI Compliance Monitoring System for Indian MSMEs",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:python": "pytest",
    "test:all": "npm run test && npm run test:python",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "deploy:dev": "cd infrastructure && terraform apply -var='environment=dev'",
    "deploy:staging": "cd infrastructure && terraform apply -var='environment=staging'",
    "deploy:prod": "cd infrastructure && terraform apply -var='environment=production'",
    "infra:init": "cd infrastructure && terraform init",
    "infra:plan": "cd infrastructure && terraform plan",
    "infra:validate": "cd infrastructure && terraform validate"
  },
  "keywords": [
    "compliance",
    "msme",
    "aws",
    "serverless",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  }
}
